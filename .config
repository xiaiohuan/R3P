CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_xiaomi_mir3p=y
CONFIG_TARGET_SQUASHFS=y
CONFIG_TARGET_ROOTFS_PARTSIZE=160

# 基础系统与主题
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-i18n-zh-cn=y
CONFIG_PACKAGE_luci-theme-argon=y

# 无线效率拉满
CONFIG_PACKAGE_wireless-regdb=y
CONFIG_PACKAGE_iw-full=y
CONFIG_PACKAGE_hostapd=y
CONFIG_PACKAGE_wpa-supplicant-full=y

# USB3.0 满血驱动
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-xhci=y
CONFIG_PACKAGE_kmod-xhci-hcd=y
CONFIG_PACKAGE_kmod-usb-storage=y

# USB网络共享（RNDIS/ECM）
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-rndis=y
CONFIG_PACKAGE_kmod-usb-net-ecm=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y

# 打印机服务
CONFIG_PACKAGE_p910nd=y
CONFIG_PACKAGE_luci-app-p910nd=y

# 局域网文件共享 Samba4
CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_luci-app-samba4=y

# 常用插件
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_openssh-sftp-server=y
