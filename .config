# 目标平台：新路由3 Newifi D2
CONFIG_TARGET_mt7621=y
CONFIG_TARGET_mt7621_DEVICE_baidu_newifi-d2=y

# 强制锁定4.4内核
CONFIG_KERNEL_VERSION_4_4=y
CONFIG_KERNEL_USE_4_4=y

# 基础系统与中文汉化
CONFIG_LUCI=y
CONFIG_LUCI_LANG_zh-cn=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# Argon美化主题+主题配置插件
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-theme-bootstrap=n

# 新路由3原生无线驱动
CONFIG_PACKAGE_kmod-mt7603=y
CONFIG_PACKAGE_kmod-mt7612e=y

# USB3.0核心驱动
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_usbmount=y
CONFIG_PACKAGE_block-mount=y

# USB网络共享
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-rndis=y
CONFIG_PACKAGE_kmod-usb-net-ipheth=y

# USB网络打印机服务
CONFIG_PACKAGE_luci-app-p910nd=y

# Samba4局域网文件共享
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_samba4-server=y

# 磁盘文件系统支持
CONFIG_PACKAGE_ntfs-3g=y
CONFIG_PACKAGE_exfat-fsck=y
CONFIG_PACKAGE_exfat-mkfs=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y

# 基础网络组件
CONFIG_PACKAGE_firewall=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_ipv6helper=y

# 常用系统工具
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
