CONFIG_TARGET_mt7621=y
CONFIG_TARGET_mt7621_DEVICE_baidu_newifi-d2=y
CONFIG_KERNEL_VERSION_4_4=y
CONFIG_KERNEL_USE_4_4=y

CONFIG_LUCI=y
CONFIG_LUCI_LANG_zh-cn=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# Argon主题
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-theme-bootstrap=n

# 无线驱动
CONFIG_PACKAGE_kmod-mt7603=y
CONFIG_PACKAGE_kmod-mt7612e=y

# USB全套
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_usbmount=y
CONFIG_PACKAGE_block-mount=y

# 打印机 & 网络共享
CONFIG_PACKAGE_luci-app-p910nd=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_samba4-server=y

# 文件系统支持
CONFIG_PACKAGE_ntfs-3g=y
CONFIG_PACKAGE_exfat-fsck=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y

# 基础网络
CONFIG_PACKAGE_firewall=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_ipv6helper=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
